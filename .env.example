# 复制本文件为 .env 并填入真实 key（.env 已被 .gitignore 忽略，不会提交）

# DeepSeek（Phase 2 默认平台）
DEEPSEEK_API_KEY=

# OpenAI GPT
OPENAI_API_KEY=

# 可选：提高抓取 README 的稳定性
GITHUB_TOKEN=

# 可选：V2EX 官方 API 2.0 Personal Access Token（https://www.v2ex.com/settings/tokens）
# 填了才用 v2 接口并支持翻页取历史；不填则回退 v1 只取最新 10 条
V2EX_API_TOKEN=
